# Copia este archivo a .env y completa los valores.
# .env esta ignorado en git. NO subir credenciales al repositorio.
# En CI / Docker / Coolify, define estas mismas variables como build args / env vars.

# Google Maps (restringir por HTTP referrer en Google Cloud Console)
GOOGLE_MAPS_API_KEY=

# URL del backend.
# API_URL_DEV -> solo build local (ng serve / development).
# API_URL     -> build de produccion (Amplify y Netlify). Cada plataforma define el suyo:
#                Amplify (main)   -> backend de produccion
#                Netlify (develop)-> backend de develop
# API_URL_DEV=http://localhost:3016/api
# API_URL=https://apiviatika.marcostorresalarcon.com/api

# Opcionales (valores por defecto en scripts/set-env.js)
# STORAGE_KEY=user-data-ls-gastos
# STORAGE_PATH=gastos-images
